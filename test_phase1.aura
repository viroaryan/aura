/*
   ==================================================
   Aura v2.0 — Phase 1 Comprehensive Test
   Testing ALL new features:
   - Boolean literals (true / false)
   - Logical operators (and / or / not)
   - else if chains
   - for loops (C-style)
   - for..in loops (foreach)
   - break / continue
   - Modulo operator (%)
   - Unary negation (-x, not x)
   ==================================================
*/

fn isEven(n) {
    return n % 2 == 0
}

fn abs(x) {
    if x < 0 {
        return -x
    }
    return x
}

fn main() {
    print("========================================")
    print("  Aura v2.0 — Phase 1 Feature Tests")
    print("========================================")

    // ---- Test 1: Boolean Literals ----
    print("\n--- Test 1: Boolean Literals ---")
    var isReady = true
    var isBroken = false
    print("isReady = " + isReady)
    print("isBroken = " + isBroken)

    // ---- Test 2: Logical Operators ----
    print("\n--- Test 2: Logical Operators ---")
    var a = true
    var b = false

    if a and not b {
        print("'a and not b' = true  ✓")
    }

    if a or b {
        print("'a or b' = true  ✓")
    }

    if not b {
        print("'not b' = true  ✓")
    }

    var x = 15
    if x > 10 and x < 20 {
        print("15 is between 10 and 20  ✓")
    }

    // ---- Test 3: else if Chains ----
    print("\n--- Test 3: else if Chains ---")
    var score = 85

    if score >= 90 {
        print("Grade: A")
    } else if score >= 80 {
        print("Grade: B  ✓  (score = 85)")
    } else if score >= 70 {
        print("Grade: C")
    } else if score >= 60 {
        print("Grade: D")
    } else {
        print("Grade: F")
    }

    // ---- Test 4: for Loop (C-style) ----
    print("\n--- Test 4: for Loop ---")
    var sum = 0
    for var i = 1; i <= 10; i = i + 1 {
        sum = sum + i
    }
    print("Sum of 1 to 10 = " + sum)

    // ---- Test 5: for..in Loop (foreach) ----
    print("\n--- Test 5: for..in Loop ---")
    var fruits = ["Apple", "Banana", "Cherry", "Date"]
    for fruit in fruits {
        print("  Fruit: " + fruit)
    }

    // ---- Test 6: break ----
    print("\n--- Test 6: break ---")
    var found = -1
    var numbers = [10, 20, 30, 42, 50]
    for var i = 0; i < 5; i = i + 1 {
        if numbers[i] == 42 {
            found = i
            break
        }
    }
    print("Found 42 at index: " + found)

    // ---- Test 7: continue ----
    print("\n--- Test 7: continue ---")
    print("Odd numbers from 1 to 10:")
    for var i = 1; i <= 10; i = i + 1 {
        if isEven(i) {
            continue
        }
        print("  " + i)
    }

    // ---- Test 8: Modulo Operator ----
    print("\n--- Test 8: Modulo Operator ---")
    print("17 % 5 = " + 17 % 5)
    print("100 % 7 = " + 100 % 7)
    print("isEven(4) = " + isEven(4))
    print("isEven(7) = " + isEven(7))

    // ---- Test 9: Unary Negation ----
    print("\n--- Test 9: Unary Negation ---")
    var positive = 42
    var negative = -positive
    print("positive = " + positive)
    print("negative = " + negative)
    print("abs(-99) = " + abs(-99))

    // ---- Test 10: Combined Complex Test ----
    print("\n--- Test 10: FizzBuzz (Combined Test) ---")
    for var i = 1; i <= 20; i = i + 1 {
        if i % 3 == 0 and i % 5 == 0 {
            print("  " + i + " -> FizzBuzz")
        } else if i % 3 == 0 {
            print("  " + i + " -> Fizz")
        } else if i % 5 == 0 {
            print("  " + i + " -> Buzz")
        }
    }

    print("\n========================================")
    print("  All Phase 1 Tests Complete! ✓")
    print("========================================")
}
