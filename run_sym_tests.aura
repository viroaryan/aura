// ---------------------------------------------------------
// Module: core/analyzer/symbol_table.aura
// Purpose: Symbol Table and Scope Management
// Description: Tracks variable declarations, function
//              signatures, and lexical scopes for type checking.
// ---------------------------------------------------------

class Symbol {
    fn init(name, type, node) {
        this.name = name
        this.type = type // "VAR", "FUNCTION", "CLASS"
        this.node = node // AST Node reference
        
        // Type checker annotations
        this.valueType = "UNKNOWN"
        this.initialized = 0
    }
}

class Scope {
    fn init(parent) {
        this.parent = parent
        this.keys = []
        this.values = [] // Array of Symbol objects
    }
    
    fn define(name, type, node) {
        // Check if already defined in the current scope
        var i = 0
        var loop = 1
        while loop == 1 {
            if i >= len(this.keys) {
                loop = 0
            } else {
                if this.keys[i] == name {
                    return 0 // Already defined
                }
                i = i + 1
            }
        }
        
        var sym = Symbol()
        sym.init(name, type, node)
        array_push(this.keys, name)
        array_push(this.values, sym)
        return 1
    }
    
    fn resolve(name) {
        var i = 0
        var loop = 1
        while loop == 1 {
            if i >= len(this.keys) {
                loop = 0
            } else {
                if this.keys[i] == name {
                    return this.values[i]
                }
                i = i + 1
            }
        }
        
        if this.parent != 0 {
            return this.parent.resolve(name)
        }
        
        // Null-ish fallback for undefined
        var errSym = Symbol()
        errSym.init("ERROR", "ERROR", 0)
        return errSym
    }
}

class SymbolTable {
    fn init() {
        this.globalScope = Scope()
        this.globalScope.init(0)
        
        this.currentScope = this.globalScope
    }
    
    fn enterScope() {
        var newScope = Scope()
        newScope.init(this.currentScope)
        this.currentScope = newScope
    }
    
    fn exitScope() {
        if this.currentScope.parent != 0 {
            this.currentScope = this.currentScope.parent
        } else {
            print("ERROR: Cannot exit global scope.")
        }
    }
    
    fn define(name, type, node) {
        return this.currentScope.define(name, type, node)
    }
    
    fn resolve(name) {
        return this.currentScope.resolve(name)
    }
}
// ---------------------------------------------------------
// Module: tests/core/analyzer/test_symbol_table.aura
// Purpose: Unit tests for the Symbol Table module
// ---------------------------------------------------------

fn test_symbol_table() {
    print("Running Symbol Table Tests...")
    var passed = 0
    var total = 0
    
    var symTable = SymbolTable()
    symTable.init()
    
    // Test 1: Global Scope definition
    var def1 = symTable.define("x", "VAR", 0)
    total = total + 1
    if def1 == 1 { passed = passed + 1 } else { print("FAIL: Could not define 'x'") }
    
    // Test 2: Cannot redefine in same scope
    var def2 = symTable.define("x", "VAR", 0)
    total = total + 1
    if def2 == 0 { passed = passed + 1 } else { print("FAIL: Allowed redefinition of 'x'") }
    
    // Test 3: Resolve in current scope
    var res1 = symTable.resolve("x")
    total = total + 1
    if res1.type == "VAR" { passed = passed + 1 } else { print("FAIL: Could not resolve 'x'") }
    
    // Test 4: Enter new scope and redefine
    symTable.enterScope()
    var def3 = symTable.define("x", "VAR", 0)
    total = total + 1
    if def3 == 1 { passed = passed + 1 } else { print("FAIL: Could not shadow 'x' in new scope") }
    
    // Test 5: Resolve shadowed variable
    symTable.define("y", "VAR", 0)
    var res2 = symTable.resolve("y")
    total = total + 1
    if res2.name == "y" { passed = passed + 1 } else { print("FAIL: Could not resolve 'y'") }
    
    // Test 6: Exit scope and test resolution
    symTable.exitScope()
    var res3 = symTable.resolve("y")
    total = total + 1
    if res3.type == "ERROR" { passed = passed + 1 } else { print("FAIL: 'y' leaked out of scope") }
    
    var res4 = symTable.resolve("x")
    total = total + 1
    if res4.name == "x" { passed = passed + 1 } else { print("FAIL: Lost 'x' after exiting scope") }
    
    print("Symbol Table Tests Completed: " + passed + " / " + total + " passed.")
}

test_symbol_table()
