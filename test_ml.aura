print("========================================")
print("  AURA MACHINE LEARNING ENGINE TEST     ")
print("========================================\n")

print("1. Creating Tensors...")
var t1 = tensor_create(2, 2)
t1[0][0] = 1
t1[0][1] = 2
t1[1][0] = 3
t1[1][1] = 4

var t2 = tensor_create(2, 2)
t2[0][0] = 2
t2[0][1] = 0
t2[1][0] = 1
t2[1][1] = 2

print("Tensor 1: " + t1)
print("Tensor 2: " + t2)

print("\n2. Matrix Multiplication (Dot Product)")
var result = tensor_dot(t1, t2)
print("Result: " + result)

print("\nExplanation:")
print("[1, 2] * [2, 1] = " + result[0][0] + " (Expected 4)")
print("[1, 2] * [0, 2] = " + result[0][1] + " (Expected 4)")
print("[3, 4] * [2, 1] = " + result[1][0] + " (Expected 10)")
print("[3, 4] * [0, 2] = " + result[1][1] + " (Expected 8)")

print("\nML ENGINE IS WORKING PERFECTLY! 🚀")
