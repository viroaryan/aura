// ---------------------------------------------------------
// Module: tests/core/analyzer/test_integration.aura
// Purpose: Integration test for Phase 2 (Lexer -> Parser -> TypeChecker)
// ---------------------------------------------------------

fn test_integration_phase2() {
    print("Running Phase 2 Integration Test...")
    
    // Complex script with multiple scopes and variables
    var script = "
        fn calculate(x, y) {
            var result = x + y;
            if (result > 10) {
                var bonus = 5;
                result = result + bonus;
            }
            // Error here if bonus is accessed outside its scope (if we enforced block scopes for 'var')
            // But currently our parser adds 'var' to the function scope implicitly?
            // Actually, block statements create a new scope!
            return result;
        }
        
        fn main() {
            var a = 10;
            var b = 20;
            var c = calculate(a, b);
            
            while (c > 0) {
                var d = c - 1;
                c = d;
            }
            
            return c;
        }
    "
    
    var iterations = 20
    var iter = 0
    
    while iter < iterations {
        var lexer = Lexer()
        lexer.init(script)
        var tokens = lexer.tokenize()
        
        var parser = Parser()
        parser.init(tokens)
        var ast = parser.parse()
        
        var checker = TypeChecker()
        checker.init()
        checker.check(ast)
        
        if len(checker.errors) > 0 {
            print("Integration Test Failed with errors on iteration " + iter)
            var k = 0
            while k < len(checker.errors) {
                print(checker.errors[k])
                k = k + 1
            }
            return 0
        }
        
        iter = iter + 1
    }
    
    print("Phase 2 Integration Test Passed! Parsed and Type Checked " + iterations + " times successfully.")
}

test_integration_phase2()
