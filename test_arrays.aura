print("========================================")
print("  AuraVM v1.1 — Arrays & For Loops Tests")
print("========================================")

print("\n--- Test 1: For Loop (C-Style) ---")
var sum = 0
for var i = 1; i <= 5; i = i + 1 {
    sum = sum + i
}
print("Sum of 1 to 5 = " + sum)

print("\n--- Test 2: Arrays (Lists) ---")
var fruits = ["Apple", "Banana", "Cherry"]
print("Fruits Array: " + fruits)
print("First fruit: " + fruits[0])
print("Third fruit: " + fruits[2])

print("\n--- Test 3: Array Modification ---")
fruits[1] = "Mango"
print("Modified Array: " + fruits)

print("\n========================================")
print("  Arrays & For Loops Executed! ✓")
print("========================================")
