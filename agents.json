{
  "project_config": {
    "name": "Large-Scale Code Generation Agent System",
    "version": "1.0",
    "description": "Coordinated multi-agent system for building million-line codebases",
    "created": "2026-07-14"
  },
  "agents": {
    "architect": {
      "name": "System Architect Agent",
      "role": "Strategic planning and module design",
      "responsibilities": [
        "System decomposition into modules",
        "Dependency graph management",
        "Architecture validation",
        "Design pattern selection",
        "Performance implications analysis"
      ],
      "triggers": [
        "New major feature",
        "Module >50K LOC",
        "Architectural decision",
        "Cross-module refactor"
      ],
      "skills": [
        "large-scale-coding-agent",
        "architecture-analysis",
        "dependency-mapping"
      ],
      "rules": {
        "max_response_length": "No limit - break into files",
        "must_provide_diagrams": true,
        "must_validate_dependencies": true,
        "refuse_tasks": false
      }
    },
    "implementer": {
      "name": "Code Implementation Agent",
      "role": "Writing production code",
      "responsibilities": [
        "Write modules following specifications",
        "Code generation from architecture",
        "Inline documentation",
        "Error handling implementation",
        "Performance optimization"
      ],
      "triggers": [
        "Implementation of module",
        "Feature coding",
        "Refactoring request",
        "Performance improvement"
      ],
      "skills": [
        "large-scale-coding-agent",
        "code-generation",
        "optimization"
      ],
      "rules": {
        "atomic_size": "500-3000 LOC per implementation",
        "must_include_docstrings": true,
        "must_include_error_handling": true,
        "refuse_tasks": false,
        "target_code_quality": "production-grade"
      }
    },
    "validator": {
      "name": "Code Validation Agent",
      "role": "Testing and verification",
      "responsibilities": [
        "Write comprehensive test suites",
        "Validate code correctness",
        "Performance benchmarking",
        "Coverage analysis",
        "Integration testing",
        "Regression detection"
      ],
      "triggers": [
        "Code completion",
        "Integration checkpoint",
        "Performance regression",
        "Release validation"
      ],
      "skills": [
        "test-strategy",
        "code-validation",
        "performance-analysis"
      ],
      "rules": {
        "minimum_test_coverage": 85,
        "must_test_edge_cases": true,
        "must_benchmark_performance": true,
        "refuse_tasks": false
      }
    },
    "documenter": {
      "name": "Documentation Agent",
      "role": "Documentation and knowledge management",
      "responsibilities": [
        "API documentation generation",
        "Architecture documentation",
        "Usage examples",
        "Integration guides",
        "Performance guides",
        "Troubleshooting guides"
      ],
      "triggers": [
        "Module completion",
        "API finalization",
        "Release preparation",
        "Documentation gap detected"
      ],
      "skills": [
        "documentation-generation",
        "example-creation"
      ],
      "rules": {
        "must_include_examples": true,
        "must_document_apis": true,
        "must_explain_architecture": true,
        "refuse_tasks": false
      }
    },
    "debugger": {
      "name": "Debug & Recovery Agent",
      "role": "Problem solving and recovery",
      "responsibilities": [
        "Analyze failed tests",
        "Debug complex issues",
        "Recover from architectural problems",
        "Performance bottleneck analysis",
        "Error message improvement"
      ],
      "triggers": [
        "Test failure",
        "Performance regression",
        "Architectural issue",
        "Runtime error"
      ],
      "skills": [
        "debugging",
        "problem-analysis",
        "recovery"
      ],
      "rules": {
        "provide_root_cause_analysis": true,
        "suggest_fixes_and_tests": true,
        "refuse_tasks": false
      }
    }
  },
  "orchestration": {
    "typical_workflow": [
      {
        "phase": "Planning",
        "agents": ["architect"],
        "duration": "1-2 days",
        "outputs": [
          "Module architecture",
          "Dependency graph",
          "Implementation order",
          "Success criteria"
        ]
      },
      {
        "phase": "Core Implementation",
        "agents": ["implementer", "validator"],
        "duration": "Per module: 2-5 days",
        "outputs": [
          "Production code",
          "Unit tests",
          "Integration tests",
          "Performance baseline"
        ]
      },
      {
        "phase": "Integration",
        "agents": ["validator", "debugger"],
        "duration": "1-2 days per checkpoint",
        "outputs": [
          "System tests passing",
          "No regressions",
          "Performance verified"
        ]
      },
      {
        "phase": "Documentation",
        "agents": ["documenter"],
        "duration": "Continuous + final push",
        "outputs": [
          "API docs",
          "Architecture guide",
          "Usage examples",
          "Troubleshooting guide"
        ]
      },
      {
        "phase": "Optimization & Release",
        "agents": ["implementer", "validator", "debugger"],
        "duration": "1-2 weeks",
        "outputs": [
          "Performance optimized",
          "Full test coverage",
          "Production ready"
        ]
      }
    ],
    "checkpoint_intervals": {
      "quick_check": "Every 2-5K LOC",
      "full_validation": "Every 10-20K LOC",
      "major_checkpoint": "Every 50-100K LOC",
      "release_validation": "Project milestone"
    },
    "parallel_development": {
      "enabled": true,
      "strategy": "Implement different modules in parallel with clear interfaces",
      "constraints": [
        "Module interfaces must be defined first",
        "Dependencies must be tracked",
        "Daily integration builds required",
        "Shared code review process"
      ]
    }
  },
  "code_generation_standards": {
    "atomic_module_size": {
      "min": 500,
      "max": 3000,
      "unit": "LOC"
    },
    "file_size_limits": {
      "max_per_file": 2000,
      "unit": "LOC"
    },
    "documentation_requirements": {
      "module_docstring": "Required - purpose, dependencies, exports",
      "function_docstring": "Required - input/output contracts, examples",
      "inline_comments": "For complex logic, non-obvious intent",
      "architecture_comments": "At module level"
    },
    "code_quality": {
      "test_coverage_minimum": 85,
      "cyclomatic_complexity_max": 5,
      "readability_priority": "High - new maintainers in 2 years",
      "performance_conscious": true,
      "error_handling_explicit": true
    },
    "testing_requirements": {
      "unit_tests": "Required for all public functions",
      "integration_tests": "Required for module interactions",
      "edge_case_tests": "Required for all edge cases",
      "performance_tests": "Required for critical paths",
      "regression_tests": "Required for complex bugs"
    }
  },
  "verification_checkpoints": {
    "5k_loc_checkpoint": {
      "requirements": [
        "Unit tests passing for all completed code",
        "No compiler warnings",
        "Code review checklist completed",
        "Documentation started"
      ]
    },
    "25k_loc_checkpoint": {
      "requirements": [
        "All unit tests passing",
        "Integration tests running",
        "No critical code review issues",
        "Architecture unchanged or documented"
      ]
    },
    "100k_loc_checkpoint": {
      "requirements": [
        "Full test suite passing",
        "Test coverage >=85%",
        "Performance baseline established",
        "Architecture validated",
        "Documentation up-to-date",
        "No technical debt accumulation"
      ]
    },
    "major_milestone": {
      "requirements": [
        "All tests passing",
        "Performance meets targets",
        "Full documentation complete",
        "Code review approved",
        "Deployment tested",
        "Regression suite passing"
      ]
    }
  },
  "refusal_policy": {
    "policy": "NEVER REFUSE COMPLEX TASKS",
    "strategy": "Always break tasks into manageable pieces",
    "what_to_accept": [
      "Any size codebase (100K, 500K, 1M+ LOC)",
      "Any complexity level",
      "New technologies",
      "Ambitious projects",
      "\"Impossible\" tasks"
    ],
    "how_to_handle_large_tasks": [
      "1. Acknowledge the scale",
      "2. Ask clarifying questions about architecture",
      "3. Break into modules (50-100K LOC each)",
      "4. Start with atomic pieces",
      "5. Build up incrementally",
      "6. Validate continuously",
      "7. Never say 'too large' or 'too complex'"
    ]
  },
  "intelligence_utilization": {
    "full_capabilities": [
      "Deep algorithm analysis",
      "Performance optimization",
      "Complex error recovery",
      "Architectural innovation",
      "Edge case handling",
      "Code generation",
      "Testing strategy",
      "Performance profiling",
      "Memory management",
      "Concurrency handling"
    ],
    "requirements": {
      "use_advanced_algorithms": true,
      "optimize_performance": true,
      "handle_edge_cases": true,
      "provide_rationale": true,
      "suggest_improvements": true,
      "prevent_technical_debt": true
    }
  },
  "example_project_milestones": {
    "programming_language": {
      "total_loc": 1200000,
      "month_1": {
        "modules": ["parser", "lexer", "ast", "compiler_frontend"],
        "loc": 80000,
        "deliverables": ["Core parsing", "AST generation", "Semantic analysis"]
      },
      "month_2_3": {
        "modules": ["vm", "runtime", "memory", "stdlib"],
        "loc": 500000,
        "deliverables": ["Bytecode VM", "Memory management", "Standard library"]
      },
      "month_4": {
        "modules": ["optimization", "tools", "documentation", "ecosystem"],
        "loc": 350000,
        "deliverables": ["JIT compiler", "REPL", "Debugger", "Package manager"]
      },
      "month_5_6": {
        "modules": ["advanced_features", "testing", "examples"],
        "loc": 270000,
        "deliverables": ["Advanced features", "Full test suite", "Real-world examples"]
      }
    }
  },
  "configuration": {
    "model": "claude-opus-4-6",
    "context_window": "200K tokens",
    "max_response_length": "Unlimited - split into files as needed",
    "artifact_generation": true,
    "code_execution": true,
    "file_operations": true,
    "version_control_awareness": true
  }
}
