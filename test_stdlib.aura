print("========================================")
print("  AuraVM v1.3 - Standard Library Tests  ")
print("========================================")

print("\n--- Test 1: Math Module ---")
print("sqrt(144) = " + math_sqrt(144))
print("abs(-50) = " + math_abs(-50))
print("pow(2, 8) = " + math_pow(2, 8))

print("\n--- Test 2: Utility Module ---")
var arr = [10, 20, 30, 40]
print("Array length: " + len(arr))
print("String length: " + len("Aura Language"))
print("String to Int: " + int("420"))

print("\n--- Test 3: File I/O Module ---")
var success = file_write("test_io.txt", "Hello from Aura Standard Library!")
if success {
    print("File written successfully!")
    var content = file_read("test_io.txt")
    print("Read content: " + content)
} else {
    print("File write failed!")
}

print("\n--- Test 4: Network (HTTP) Module ---")
print("Fetching random joke from API...")
// Using a simple plain-text API for testing
var joke = http_get("https://v2.jokeapi.dev/joke/Any?format=txt&safe-mode")
print("Result:\n" + joke)

print("\n========================================")
print("  Standard Library Executed!  ")
print("========================================")
