print("========================================")
print("  Aura Virtual Machine (v1.0) Tests")
print("========================================")

print("\n--- Test 1: Math & Variables ---")
var x = 10
var y = 20
var sum = x + y
print("10 + 20 = " + sum)

print("\n--- Test 2: Strings & Concatenation ---")
var lang = "Aura"
print("Welcome to " + lang + " Virtual Machine!")

print("\n--- Test 3: Booleans & Logic ---")
var isAwesome = true
var isBoring = false
if isAwesome and not isBoring {
    print("Aura VM is Awesome! ✓")
} else {
    print("This should not print.")
}

print("\n--- Test 4: While Loops & Modulo ---")
print("Counting down even numbers from 10:")
var i = 10
while i > 0 {
    if i % 2 == 0 {
        print("  " + i)
    }
    i = i - 1
}

print("\n========================================")
print("  All VM Tests Executed Successfully! ✓")
